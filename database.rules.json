{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "shared_user": {
        ".read": "auth != null",
        ".write": "auth != null",
        "domains": {
          ".indexOn": ["created_at", "status"],
          "$domainId": {
            ".validate": "newData.hasChildren(['name', 'namespace', 'fqdn', 'status', 'created_at']) && newData.child('fqdn').isString() && newData.child('status').val().matches(/^(active|pending|error|deleted)$/) && newData.child('created_at').isNumber()"
          }
        }
      },
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "domains": {
          ".indexOn": ["created_at", "status"],
          "$domainId": {
            ".validate": "newData.hasChildren(['name', 'namespace', 'fqdn', 'status', 'created_at']) && newData.child('fqdn').isString() && newData.child('status').val().matches(/^(active|pending|error|deleted)$/) && newData.child('created_at').isNumber()"
          }
        }
      }
    },
    "logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
